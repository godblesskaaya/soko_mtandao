SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AzamPay credentials
AZAMPAY_APP_NAME=your-app-name
AZAMPAY_CLIENT_ID=your-client-id
AZAMPAY_CLIENT_SECRET=your-client-secret
AZAMPAY_API_KEY=your-api-key

# Optional endpoint overrides
AZAMPAY_AUTH_URL=https://authenticator-sandbox.azampay.co.tz/AppRegistration/GenerateToken
AZAMPAY_API_BASE_URL=https://sandbox.azampay.co.tz
AZAMPAY_CHECKOUT_URL=https://sandbox.azampay.co.tz/api/v1/Partner/PostCheckout
AZAMPAY_DISBURSE_URL=https://api-disbursement-sandbox.azampay.co.tz/api/v1/azampay/disburse

# Optional checkout behavior
AZAMPAY_REDIRECT_SUCCESS_URL=https://yourapp.com/payment-success
AZAMPAY_REDIRECT_FAIL_URL=https://yourapp.com/payment-failed
AZAMPAY_REQUEST_ORIGIN=https://yourapp.com
AZAMPAY_VENDOR_ID=
AZAMPAY_VENDOR_NAME=

# Payment settlement behavior
SETTLEMENT_HOLD_HOURS=24
